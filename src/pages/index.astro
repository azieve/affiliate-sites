---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ServiceCard from '@/components/affiliate/ServiceCard.astro';
import Button from '@/components/ui/Button.astro';
import { siteConfig } from '@/data/site';
import { services } from '@/data/services';

const title = 'Best LLC Formation Services (2026) — Expert Reviews & Comparisons';
const description =
  'Compare the top LLC formation services with expert reviews, state-by-state guides, and honest comparisons. Find the right service for your business today.';

const topServices = ['northwest', 'zenbusiness', 'legalzoom'];

const stateGuides = [
  { name: 'Texas', href: '/start-llc/texas/' },
  { name: 'Florida', href: '/start-llc/florida/' },
  { name: 'California', href: '/start-llc/california/' },
  { name: 'Delaware', href: '/start-llc/delaware/' },
  { name: 'New York', href: '/start-llc/new-york/' },
  { name: 'Wyoming', href: '/start-llc/wyoming/' },
];

const latestReviews = [
  {
    name: services.northwest.name,
    slug: services.northwest.reviewSlug,
    rating: services.northwest.rating,
    bestFor: services.northwest.bestFor,
    price: services.northwest.formationPrice,
  },
  {
    name: services.zenbusiness.name,
    slug: services.zenbusiness.reviewSlug,
    rating: services.zenbusiness.rating,
    bestFor: services.zenbusiness.bestFor,
    price: services.zenbusiness.formationPrice,
  },
  {
    name: services.legalzoom.name,
    slug: services.legalzoom.reviewSlug,
    rating: services.legalzoom.rating,
    bestFor: services.legalzoom.bestFor,
    price: services.legalzoom.formationPrice,
  },
  {
    name: services.bizee.name,
    slug: services.bizee.reviewSlug,
    rating: services.bizee.rating,
    bestFor: services.bizee.bestFor,
    price: services.bizee.formationPrice,
  },
];

const resources = [
  {
    title: 'What Is an LLC?',
    desc: 'Learn the basics of limited liability companies and whether one is right for you.',
    href: '/learn/what-is-an-llc/',
    icon: 'book',
  },
  {
    title: 'How Much Does an LLC Cost?',
    desc: 'State fees, formation service costs, and ongoing expenses broken down.',
    href: '/learn/how-much-does-an-llc-cost/',
    icon: 'dollar',
  },
  {
    title: 'Start an LLC by State',
    desc: 'Step-by-step guides for forming your LLC in all 50 states.',
    href: '/start-llc/',
    icon: 'map',
  },
  {
    title: 'LLC Operating Agreement',
    desc: 'Why you need one and how to create a solid operating agreement.',
    href: '/learn/llc-operating-agreement/',
    icon: 'doc',
  },
];

const insights = [
  {
    title: 'ZenBusiness vs LegalZoom',
    desc: 'A detailed side-by-side comparison of two popular formation services.',
    href: '/compare/zenbusiness-vs-legalzoom/',
  },
  {
    title: 'Northwest vs ZenBusiness',
    desc: 'Which formation service offers better value for your money?',
    href: '/compare/northwest-vs-zenbusiness/',
  },
  {
    title: 'LLC for Freelancers',
    desc: 'Should you form an LLC as a freelancer? Pros, cons, and how to decide.',
    href: '/llc-for/freelancers/',
  },
  {
    title: 'LLC vs Sole Proprietorship',
    desc: 'Compare legal protection, taxes, and costs of each business structure.',
    href: '/learn/llc-vs-sole-proprietorship/',
  },
];

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteConfig.name,
  url: siteConfig.url,
  description: siteConfig.description,
  publisher: {
    '@type': 'Organization',
    name: siteConfig.name,
    url: siteConfig.url,
  },
});
---

<BaseLayout title={title} description={description} schema={schema}>
  <!-- ====== HERO SECTION ====== -->
  <section class="relative overflow-hidden bg-gradient-to-br from-[#1e3a5f] via-[#1e3a5f] to-[#0d9488]/80">
    <!-- Decorative shapes -->
    <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
      <div class="absolute -right-20 -top-20 h-72 w-72 rounded-full bg-white/5"></div>
      <div class="absolute -bottom-32 -left-16 h-96 w-96 rounded-full bg-[#0d9488]/10"></div>
      <div class="absolute right-1/4 top-1/3 h-48 w-48 rounded-full bg-white/5"></div>
    </div>

    <div class="relative mx-auto max-w-6xl px-4 py-20 sm:px-6 sm:py-28 lg:py-36">
      <div class="mx-auto max-w-3xl text-center">
        <h1 class="text-4xl font-extrabold leading-tight tracking-tight text-white sm:text-5xl lg:text-6xl">
          Find the Best LLC Formation Service for Your Business
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-blue-100 sm:text-xl">
          Expert reviews, state-by-state guides, and honest comparisons to help you form your LLC with confidence.
        </p>

        <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
          <Button href="/best-llc-services/" variant="primary" size="lg">
            Compare Services
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
            </svg>
          </Button>
          <Button href="/start-llc/" variant="outline" size="lg" class="border-white/40 text-white hover:bg-white/10 hover:text-white">
            Browse State Guides
          </Button>
        </div>

        <!-- Trust badges -->
        <div class="mt-12 flex flex-wrap items-center justify-center gap-6 text-sm text-blue-200">
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-teal-300" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
            </svg>
            <span>5 Services Reviewed</span>
          </div>
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-teal-300" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
            </svg>
            <span>50 State Guides</span>
          </div>
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-teal-300" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
            </svg>
            <span>Updated March 2026</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== TOP 3 SERVICES ====== -->
  <section class="bg-gray-50 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <div class="text-center">
        <h2 class="text-3xl font-extrabold text-gray-900 sm:text-4xl">
          Our Top-Rated LLC Formation Services
        </h2>
        <p class="mt-3 text-lg text-gray-600">
          Independently researched and reviewed to help you make the best choice.
        </p>
      </div>

      <div class="mt-10 space-y-6">
        {topServices.map((id, i) => (
          <ServiceCard serviceId={id} rank={i + 1} />
        ))}
      </div>

      <div class="mt-10 text-center">
        <Button href="/best-llc-services/" variant="secondary" size="lg">
          See All 5 Services Compared
        </Button>
      </div>
    </div>
  </section>

  <!-- ====== HOW IT WORKS ====== -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="text-center">
        <h2 class="text-3xl font-extrabold text-gray-900 sm:text-4xl">
          Form Your LLC in 3 Simple Steps
        </h2>
        <p class="mt-3 text-lg text-gray-600">
          Starting a business doesn't have to be complicated.
        </p>
      </div>

      <div class="mt-12 grid gap-8 sm:grid-cols-3">
        <!-- Step 1 -->
        <div class="relative text-center">
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-gradient-to-br from-[#1e3a5f] to-[#0d9488] text-2xl font-extrabold text-white shadow-lg">
            1
          </div>
          <h3 class="mt-5 text-xl font-bold text-gray-900">Choose Your State</h3>
          <p class="mt-2 text-gray-600">
            Every state has different fees and requirements. Our state guides walk you through everything.
          </p>
          <!-- Connector arrow (hidden on mobile) -->
          <div class="absolute right-0 top-8 hidden -translate-y-1/2 translate-x-1/2 sm:block" aria-hidden="true">
            <svg class="h-6 w-6 text-gray-300" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="relative text-center">
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-gradient-to-br from-[#1e3a5f] to-[#0d9488] text-2xl font-extrabold text-white shadow-lg">
            2
          </div>
          <h3 class="mt-5 text-xl font-bold text-gray-900">Pick a Service</h3>
          <p class="mt-2 text-gray-600">
            Compare pricing, features, and real user experiences to find the right formation service.
          </p>
          <div class="absolute right-0 top-8 hidden -translate-y-1/2 translate-x-1/2 sm:block" aria-hidden="true">
            <svg class="h-6 w-6 text-gray-300" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="text-center">
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-gradient-to-br from-[#1e3a5f] to-[#0d9488] text-2xl font-extrabold text-white shadow-lg">
            3
          </div>
          <h3 class="mt-5 text-xl font-bold text-gray-900">Form Your LLC</h3>
          <p class="mt-2 text-gray-600">
            Complete your filing online in minutes. Your formation service handles the paperwork.
          </p>
        </div>
      </div>

      <div class="mt-12 text-center">
        <Button href="/start-llc/" variant="outline" size="lg">
          Browse State Guides
        </Button>
      </div>
    </div>
  </section>

  <!-- ====== LATEST REVIEWS ====== -->
  <section class="bg-gray-50 py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="flex items-end justify-between">
        <div>
          <h2 class="text-3xl font-extrabold text-gray-900">Latest Reviews</h2>
          <p class="mt-2 text-gray-600">In-depth, hands-on reviews of top LLC formation services.</p>
        </div>
        <a href="/best-llc-services/" class="hidden text-sm font-semibold text-teal-700 hover:text-teal-900 sm:block">
          View all &rarr;
        </a>
      </div>

      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {latestReviews.map((review) => (
          <a
            href={`/reviews/${review.slug}/`}
            class="group rounded-xl border border-gray-200 bg-white p-5 shadow-sm transition-all hover:border-teal-200 hover:shadow-md"
          >
            <div class="flex items-center justify-between">
              <span class="rounded-md bg-teal-100 px-2 py-0.5 text-sm font-bold text-teal-800">
                {review.rating}/10
              </span>
              <span class="text-xs font-medium text-gray-400">Review</span>
            </div>
            <h3 class="mt-3 text-lg font-bold text-gray-900 group-hover:text-teal-700">
              {review.name}
            </h3>
            <p class="mt-1 text-sm text-gray-500">{review.bestFor}</p>
            <p class="mt-3 text-sm font-medium text-gray-700">
              From <span class="text-teal-700">{review.price}</span> + state fees
            </p>
            <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-teal-700 group-hover:underline">
              Read review
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== RESOURCES ====== -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="flex items-end justify-between">
        <div>
          <h2 class="text-3xl font-extrabold text-gray-900">Resources</h2>
          <p class="mt-2 text-gray-600">Everything you need to know about forming and running an LLC.</p>
        </div>
      </div>

      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {resources.map((resource) => (
          <a
            href={resource.href}
            class="group rounded-xl border border-gray-200 bg-white p-5 shadow-sm transition-all hover:border-teal-200 hover:shadow-md"
          >
            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-[#1e3a5f]/10">
              {resource.icon === 'book' && (
                <svg class="h-5 w-5 text-[#1e3a5f]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path d="M10.75 16.82A7.462 7.462 0 0115 15.5c.71 0 1.396.098 2.046.282A.75.75 0 0018 15.06v-11a.75.75 0 00-.546-.721A9.006 9.006 0 0015 3a8.999 8.999 0 00-4.25 1.065v12.755zM9.25 4.065A8.999 8.999 0 005 3c-.85 0-1.673.118-2.454.339A.75.75 0 002 4.06v11a.75.75 0 00.954.721A7.506 7.506 0 015 15.5c1.579 0 3.042.487 4.25 1.32V4.065z" />
                </svg>
              )}
              {resource.icon === 'dollar' && (
                <svg class="h-5 w-5 text-[#1e3a5f]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path d="M10.75 10.818a2.4 2.4 0 01-.87.456 3.39 3.39 0 01-.98.14c-.35 0-.69-.06-.99-.17a1.87 1.87 0 01-.77-.5 2.22 2.22 0 01-.49-.85 3.86 3.86 0 01-.17-1.2c0-.47.06-.88.19-1.23.13-.35.3-.64.53-.87.22-.23.49-.4.79-.52.31-.12.64-.18 1-.18.36 0 .66.06.93.17.27.12.5.28.68.49l.94-.94a2.84 2.84 0 00-1.09-.74 3.77 3.77 0 00-1.46-.27c-.57 0-1.09.1-1.57.3a3.37 3.37 0 00-1.22.85c-.34.36-.6.81-.78 1.33a5.1 5.1 0 00-.27 1.72c0 .64.09 1.21.28 1.72.19.51.45.95.79 1.31.34.37.75.65 1.22.85.47.2.99.3 1.56.3.58 0 1.08-.09 1.5-.28.42-.18.79-.44 1.1-.76l-.95-.94z" />
                </svg>
              )}
              {resource.icon === 'map' && (
                <svg class="h-5 w-5 text-[#1e3a5f]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M8.157 2.175a1.5 1.5 0 00-1.147 0l-4.084 1.69A1.5 1.5 0 002 5.251v10.877a1.5 1.5 0 002.074 1.386l3.51-1.453 4.26 1.763a1.5 1.5 0 001.146 0l4.084-1.69A1.5 1.5 0 0018 14.748V3.873a1.5 1.5 0 00-2.074-1.386l-3.51 1.453-4.26-1.763zM7.58 5a.75.75 0 01.75.75v6.5a.75.75 0 01-1.5 0v-6.5A.75.75 0 017.58 5zm5.59 2.75a.75.75 0 00-1.5 0v6.5a.75.75 0 001.5 0v-6.5z" clip-rule="evenodd" />
                </svg>
              )}
              {resource.icon === 'doc' && (
                <svg class="h-5 w-5 text-[#1e3a5f]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M4.5 2A1.5 1.5 0 003 3.5v13A1.5 1.5 0 004.5 18h11a1.5 1.5 0 001.5-1.5V7.621a1.5 1.5 0 00-.44-1.06l-4.12-4.122A1.5 1.5 0 0011.378 2H4.5zm2.25 8.5a.75.75 0 000 1.5h6.5a.75.75 0 000-1.5h-6.5zm0 3a.75.75 0 000 1.5h6.5a.75.75 0 000-1.5h-6.5z" clip-rule="evenodd" />
                </svg>
              )}
            </div>
            <h3 class="mt-4 text-lg font-bold text-gray-900 group-hover:text-teal-700">
              {resource.title}
            </h3>
            <p class="mt-1.5 text-sm leading-relaxed text-gray-600">{resource.desc}</p>
          </a>
        ))}
      </div>

      <!-- Popular State Guides -->
      <div class="mt-12 rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
        <h3 class="text-lg font-bold text-gray-900">Popular State Guides</h3>
        <div class="mt-4 grid gap-3 sm:grid-cols-3 lg:grid-cols-6">
          {stateGuides.map((state) => (
            <a
              href={state.href}
              class="rounded-lg border border-gray-100 bg-gray-50 px-4 py-3 text-center text-sm font-medium text-gray-700 transition-colors hover:border-teal-200 hover:bg-teal-50 hover:text-teal-700"
            >
              {state.name}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ====== INSIGHTS ====== -->
  <section class="bg-gray-50 py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="flex items-end justify-between">
        <div>
          <h2 class="text-3xl font-extrabold text-gray-900">Insights</h2>
          <p class="mt-2 text-gray-600">Comparisons, guides, and advice for different business types.</p>
        </div>
      </div>

      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {insights.map((insight) => (
          <a
            href={insight.href}
            class="group rounded-xl border border-gray-200 bg-white p-5 shadow-sm transition-all hover:border-teal-200 hover:shadow-md"
          >
            <span class="inline-block rounded-full bg-[#1e3a5f]/10 px-3 py-1 text-xs font-semibold text-[#1e3a5f]">
              Insight
            </span>
            <h3 class="mt-3 text-lg font-bold text-gray-900 group-hover:text-teal-700">
              {insight.title}
            </h3>
            <p class="mt-1.5 text-sm leading-relaxed text-gray-600">{insight.desc}</p>
            <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-teal-700 group-hover:underline">
              Read more
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== WHY TRUST US ====== -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <div class="rounded-2xl border border-gray-200 bg-gradient-to-br from-white to-gray-50 p-8 text-center shadow-sm sm:p-12">
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-[#1e3a5f]/10">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-[#1e3a5f]" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 1a4.5 4.5 0 00-4.5 4.5V9H5a2 2 0 00-2 2v6a2 2 0 002 2h10a2 2 0 002-2v-6a2 2 0 00-2-2h-.5V5.5A4.5 4.5 0 0010 1zm3 8V5.5a3 3 0 10-6 0V9h6z" clip-rule="evenodd" />
          </svg>
        </div>
        <h2 class="mt-5 text-2xl font-extrabold text-gray-900 sm:text-3xl">Why Trust Our Reviews?</h2>
        <p class="mt-4 text-gray-600 leading-relaxed">
          Our editorial team spends hundreds of hours researching, testing, and comparing LLC formation services. We sign up for every service, evaluate the real user experience, and provide honest assessments. While we may earn commissions from some services, our ratings are never influenced by compensation. Your trust is our top priority.
        </p>
        <div class="mt-6 flex flex-wrap items-center justify-center gap-6 text-sm text-gray-500">
          <span class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-green-500" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
            </svg>
            Independent research
          </span>
          <span class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-green-500" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
