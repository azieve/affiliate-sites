---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/data/site';
import { services } from '@/data/services';

const title = 'LLC Service Comparisons';
const description =
  'Side-by-side comparisons of the top LLC formation services. See how ZenBusiness, LegalZoom, Northwest, Bizee, and more stack up on pricing, features, and value.';

const comparisons = [
  {
    title: 'ZenBusiness vs LegalZoom',
    slug: 'zenbusiness-vs-legalzoom',
    desc: 'Two of the most popular LLC services compared head-to-head. ZenBusiness offers affordable pricing while LegalZoom brings brand recognition and legal add-ons.',
    serviceA: services.zenbusiness,
    serviceB: services.legalzoom,
  },
  {
    title: 'Northwest vs ZenBusiness',
    slug: 'northwest-vs-zenbusiness',
    desc: 'Privacy-focused Northwest goes up against beginner-friendly ZenBusiness. Both offer excellent value but take very different approaches to LLC formation.',
    serviceA: services.northwest,
    serviceB: services.zenbusiness,
  },
];
---

<BaseLayout title={title} description={description}>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-[#1e3a5f] to-[#1e3a5f]/90 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
      <h1 class="text-3xl font-extrabold text-white sm:text-4xl lg:text-5xl">
        LLC Service Comparisons
      </h1>
      <p class="mt-4 text-lg leading-relaxed text-blue-100">
        Not sure which LLC service to choose? Our side-by-side comparisons break down pricing, features, customer support, and overall value so you can make the right decision.
      </p>
    </div>
  </section>

  <article class="mx-auto max-w-4xl px-4 py-12 sm:px-6 sm:py-16">

    <!-- Why Comparisons Help -->
    <section class="mb-12">
      <h2 class="text-2xl font-extrabold text-gray-900 sm:text-3xl">Why Comparisons Matter</h2>
      <div class="mt-4 space-y-4 text-gray-700 leading-relaxed">
        <p>
          Every LLC formation service has its strengths and trade-offs. Some offer the lowest price but lack features. Others include everything but charge a premium. And a few find the sweet spot in between.
        </p>
        <p>
          Our comparison guides put two services side by side and evaluate them across the criteria that matter most: formation pricing, registered agent costs, included features, processing speed, customer support quality, and overall value. Each comparison includes a clear verdict to help you decide.
        </p>
        <p>
          If you want the full picture, check out our <a href="/best-llc-services/" class="text-teal-700 underline underline-offset-2 hover:text-teal-900">complete ranking of the best LLC services</a>.
        </p>
      </div>
    </section>

    <!-- Comparison Cards -->
    <section class="mb-16">
      <h2 class="text-2xl font-extrabold text-gray-900 sm:text-3xl">Our Comparisons</h2>

      <div class="mt-8 space-y-6">
        {comparisons.map((comp) => (
          <a
            href={`/compare/${comp.slug}/`}
            class="group block rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md"
          >
            <h3 class="text-xl font-bold text-gray-900 group-hover:text-teal-700">{comp.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-gray-600">{comp.desc}</p>

            <div class="mt-4 flex flex-wrap gap-4">
              <div class="rounded-lg bg-gray-50 px-4 py-2">
                <span class="text-xs font-semibold text-gray-500">{comp.serviceA.shortName}</span>
                <p class="text-sm font-bold text-gray-900">{comp.serviceA.rating}/10 &middot; From {comp.serviceA.formationPrice}</p>
              </div>
              <div class="flex items-center text-sm font-bold text-gray-400">vs</div>
              <div class="rounded-lg bg-gray-50 px-4 py-2">
                <span class="text-xs font-semibold text-gray-500">{comp.serviceB.shortName}</span>
                <p class="text-sm font-bold text-gray-900">{comp.serviceB.rating}/10 &middot; From {comp.serviceB.formationPrice}</p>
              </div>
            </div>

            <span class="mt-4 inline-block text-sm font-semibold text-teal-700 group-hover:underline">
              Read full comparison &rarr;
            </span>
          </a>
        ))}
      </div>
    </section>

    <!-- More Comparisons Coming -->
    <section class="mb-16">
      <div class="rounded-xl border border-gray-200 bg-gray-50/50 p-6 text-center">
        <h2 class="text-xl font-bold text-gray-900">More Comparisons Coming Soon</h2>
        <p class="mt-2 text-sm text-gray-600">
          We are working on additional head-to-head comparisons, including Bizee vs ZenBusiness, Northwest vs LegalZoom, and more. Check back regularly for updates.
        </p>
      </div>
    </section>

    <!-- CTA -->
    <section class="mb-12">
      <div class="rounded-xl border border-teal-200 bg-teal-50/50 p-6 text-center">
        <h2 class="text-xl font-bold text-gray-900">See the Full Rankings</h2>
        <p class="mt-2 text-sm text-gray-700">
          Want to see all the top LLC services ranked side by side? Our comprehensive guide covers pricing, features, and our overall verdict for each provider.
        </p>
        <a
          href="/best-llc-services/"
          class="mt-4 inline-block rounded-lg bg-teal-700 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-teal-800"
        >
          Best LLC Services 2026
        </a>
      </div>
    </section>

    <!-- Affiliate Disclosure -->
    <div class="mb-8 rounded-xl border border-amber-200 bg-amber-50/50 p-4 text-xs leading-relaxed text-gray-600">
      {siteConfig.disclosureText}
    </div>

    <div class="border-t border-gray-200 pt-8 text-center text-sm text-gray-500">
      <p>{siteConfig.name} is operated by {siteConfig.operator}.</p>
    </div>
  </article>
</BaseLayout>
