---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/data/site';

const title = 'LLC Formation Blog — Expert Guides & Insights';
const description =
  'Expert articles on LLC formation, business compliance, state guides, and more. Get practical advice from business formation professionals.';

const posts = await getCollection('blog', ({ data }) => !data.draft);

const sortedPosts = posts.sort(
  (a, b) =>
    new Date(b.data.publishDate).getTime() -
    new Date(a.data.publishDate).getTime()
);

function formatDate(dateStr: string): string {
  return new Date(dateStr + 'T00:00:00').toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

const categories = [...new Set(sortedPosts.map((p) => p.data.category))];
---

<BaseLayout title={title} description={description}>
  <!-- Hero -->
  <section
    class="bg-gradient-to-br from-[#1e3a5f] to-[#1e3a5f]/90 py-16 sm:py-20"
  >
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
      <p
        class="text-sm font-semibold uppercase tracking-wider text-teal-300"
      >
        Blog
      </p>
      <h1
        class="mt-3 text-3xl font-extrabold text-white sm:text-4xl lg:text-5xl"
      >
        LLC Formation Insights
      </h1>
      <p class="mt-4 text-lg text-gray-300">
        Expert guides, state-by-state breakdowns, and practical advice for
        forming and managing your LLC.
      </p>
    </div>
  </section>

  <!-- Posts grid -->
  <section class="container py-12 lg:py-16">
    {sortedPosts.length === 0 ? (
      <div class="text-center py-16">
        <p class="text-lg text-text-muted">
          No articles published yet. Check back soon!
        </p>
      </div>
    ) : (
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {sortedPosts.map((post) => (
          <a
            href={`/blog/${post.id}/`}
            class="group flex flex-col rounded-lg border border-border bg-surface transition-shadow hover:shadow-lg"
          >
            <div class="flex flex-1 flex-col p-6">
              <span class="mb-2 inline-block w-fit rounded-full bg-brand-navy/10 px-3 py-1 text-xs font-semibold text-brand-navy">
                {post.data.category}
              </span>
              <h2 class="mb-2 text-lg font-bold text-text-primary group-hover:text-brand-teal transition-colors">
                {post.data.title}
              </h2>
              <p class="mb-4 flex-1 text-sm text-text-secondary line-clamp-3">
                {post.data.metaDescription}
              </p>
              <div class="flex items-center gap-3 text-xs text-text-muted">
                <span>{post.data.author}</span>
                <span>·</span>
                <time datetime={post.data.publishDate}>
                  {formatDate(post.data.publishDate)}
                </time>
              </div>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
