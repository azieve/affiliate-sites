---
interface Props {
  rating: number;
  size?: "sm" | "md" | "lg";
  showNumeric?: boolean;
}

const { rating, size = "md", showNumeric = false } = Astro.props;

const clampedRating = Math.max(0, Math.min(5, rating));
const fullStars = Math.floor(clampedRating);
const hasHalfStar = clampedRating % 1 >= 0.25 && clampedRating % 1 < 0.75;
const adjustedFull = clampedRating % 1 >= 0.75 ? fullStars + 1 : fullStars;
const emptyStars = 5 - adjustedFull - (hasHalfStar ? 1 : 0);

const sizeClasses: Record<string, string> = {
  sm: "h-4 w-4",
  md: "h-5 w-5",
  lg: "h-6 w-6",
};

const textSizeClasses: Record<string, string> = {
  sm: "text-xs",
  md: "text-sm",
  lg: "text-base",
};

const starSize = sizeClasses[size];
const textSize = textSizeClasses[size];
---

<div class="inline-flex items-center gap-1" role="img" aria-label={`Rating: ${clampedRating} out of 5 stars`}>
  <div class="flex gap-0.5">
    {/* Full stars */}
    {Array.from({ length: adjustedFull }).map(() => (
      <svg class={`${starSize} text-amber-400`} viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
    ))}

    {/* Half star */}
    {hasHalfStar && (
      <svg class={`${starSize} text-amber-400`} viewBox="0 0 20 20" aria-hidden="true">
        <defs>
          <linearGradient id="half-star-grad">
            <stop offset="50%" stop-color="currentColor" />
            <stop offset="50%" stop-color="#D1D5DB" />
          </linearGradient>
        </defs>
        <path
          fill="url(#half-star-grad)"
          d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
        />
      </svg>
    )}

    {/* Empty stars */}
    {Array.from({ length: emptyStars }).map(() => (
      <svg class={`${starSize} text-gray-300`} viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
    ))}
  </div>

  {showNumeric && (
    <span class={`${textSize} font-medium text-gray-600 ml-1`}>
      {clampedRating.toFixed(1)}/5
    </span>
  )}
</div>
