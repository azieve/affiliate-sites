---
/**
 * ProsCons - Two-column pros/cons display.
 *
 * Renders green checkmarks for pros and red X icons for cons.
 * Stacks to a single column on mobile.
 */
interface Props {
  pros: string[];
  cons: string[];
}

const { pros, cons } = Astro.props;
---

<div class="grid gap-4 sm:grid-cols-2">
  {/* Pros */}
  <div class="rounded-lg border border-green-200 bg-green-50/50 p-4">
    <h4 class="mb-3 flex items-center gap-2 text-sm font-bold uppercase tracking-wider text-green-800">
      <svg
        class="h-5 w-5 text-green-600"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 20 20"
        fill="currentColor"
        aria-hidden="true"
      >
        <path
          fill-rule="evenodd"
          d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z"
          clip-rule="evenodd"
        />
      </svg>
      Pros
    </h4>
    <ul class="space-y-2" role="list">
      {pros.map((pro) => (
        <li class="flex items-start gap-2 text-sm text-gray-700">
          <svg
            class="mt-0.5 h-4 w-4 shrink-0 text-green-500"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 20 20"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z"
              clip-rule="evenodd"
            />
          </svg>
          <span>{pro}</span>
        </li>
      ))}
    </ul>
  </div>

  {/* Cons */}
  <div class="rounded-lg border border-red-200 bg-red-50/50 p-4">
    <h4 class="mb-3 flex items-center gap-2 text-sm font-bold uppercase tracking-wider text-red-800">
      <svg
        class="h-5 w-5 text-red-500"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 20 20"
        fill="currentColor"
        aria-hidden="true"
      >
        <path
          fill-rule="evenodd"
          d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z"
          clip-rule="evenodd"
        />
      </svg>
      Cons
    </h4>
    <ul class="space-y-2" role="list">
      {cons.map((con) => (
        <li class="flex items-start gap-2 text-sm text-gray-700">
          <svg
            class="mt-0.5 h-4 w-4 shrink-0 text-red-400"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 20 20"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z"
            />
          </svg>
          <span>{con}</span>
        </li>
      ))}
    </ul>
  </div>
</div>
