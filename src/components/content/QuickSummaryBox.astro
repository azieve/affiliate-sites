---
/**
 * QuickSummaryBox - TL;DR summary at the top of articles.
 *
 * Shows a verdict, optional top recommendation with CTA, and
 * a slot for any additional summary content.
 */
import { getRedirectUrl, affiliatePrograms } from '@/data/affiliates';
import { services } from '@/data/services';

interface Props {
  verdict: string;
  serviceId?: string;
  rating?: number;
}

const { verdict, serviceId, rating } = Astro.props;

const service = serviceId ? services[serviceId] : null;
const affiliate = serviceId
  ? affiliatePrograms[serviceId as keyof typeof affiliatePrograms]
  : null;
const href = serviceId ? getRedirectUrl(serviceId as any) : null;
---

<aside
  class="rounded-xl border border-blue-200 bg-gradient-to-br from-blue-50 to-slate-50 p-5 sm:p-6"
  role="complementary"
  aria-label="Quick summary"
>
  <div class="flex items-center gap-2">
    <svg
      class="h-5 w-5 text-blue-600"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 20 20"
      fill="currentColor"
      aria-hidden="true"
    >
      <path
        fill-rule="evenodd"
        d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a.75.75 0 000 1.5h.253a.25.25 0 01.244.304l-.459 2.066A1.75 1.75 0 0010.747 15H11a.75.75 0 000-1.5h-.253a.25.25 0 01-.244-.304l.459-2.066A1.75 1.75 0 009.253 9H9z"
        clip-rule="evenodd"
      />
    </svg>
    <h2 class="text-lg font-bold text-gray-900">Quick Summary</h2>
  </div>

  <p class="mt-3 text-[15px] leading-relaxed text-gray-700">{verdict}</p>

  {/* Optional rating display */}
  {rating && (
    <div class="mt-3 flex items-center gap-2">
      <span class="rounded-md bg-teal-100 px-2.5 py-1 text-sm font-bold text-teal-800">
        {rating}/10
      </span>
      <span class="text-sm text-gray-500">Overall Score</span>
    </div>
  )}

  {/* Top recommendation CTA */}
  {service && affiliate && href && (
    <div class="mt-4 flex flex-col gap-2 rounded-lg border border-teal-200 bg-white p-3 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider text-teal-600">
          Our Top Pick
        </p>
        <p class="font-semibold text-gray-900">{service.name}</p>
        <p class="text-sm text-gray-500">
          From {service.formationPrice} &middot; {service.bestFor}
        </p>
      </div>
      <a
        href={href}
        rel="nofollow sponsored"
        target="_blank"
        class="inline-flex shrink-0 items-center justify-center gap-1.5 rounded-md bg-teal-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-teal-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-teal-600"
      >
        {affiliate.cta}
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>
  )}

  {/* Slot for additional content */}
  <slot />
</aside>
