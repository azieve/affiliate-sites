---
import { siteConfig } from '@/data/site';

const { footerLinks, currentYear } = siteConfig;
---

<footer class="border-t border-border bg-brand-navy text-white">
  <div class="container py-12">
    <!-- Footer columns -->
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <!-- About column -->
      <div class="lg:col-span-1">
        <a href="/" class="mb-4 inline-block text-lg font-bold text-white">
          TopBestLLCService
        </a>
        <p class="mb-4 text-sm leading-relaxed text-slate-300">
          Expert reviews and comparisons to help you find the best LLC formation
          service for your business. We research, test, and evaluate so you can
          make an informed decision.
        </p>
        <p class="text-xs leading-relaxed text-slate-400">
          This site contains affiliate links. We may earn a commission when you
          use our links to purchase services, at no extra cost to you.
        </p>
      </div>

      <!-- Company links -->
      <div>
        <h3 class="mb-4 text-sm font-semibold uppercase tracking-wider text-slate-300">
          Company
        </h3>
        <ul class="space-y-2">
          {footerLinks.company.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-slate-300 transition-colors hover:text-white"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Reviews links -->
      <div>
        <h3 class="mb-4 text-sm font-semibold uppercase tracking-wider text-slate-300">
          Reviews
        </h3>
        <ul class="space-y-2">
          {footerLinks.reviews.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-slate-300 transition-colors hover:text-white"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Popular Guides links -->
      <div>
        <h3 class="mb-4 text-sm font-semibold uppercase tracking-wider text-slate-300">
          Popular Guides
        </h3>
        <ul class="space-y-2">
          {footerLinks.guides.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-slate-300 transition-colors hover:text-white"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-10 border-t border-slate-600 pt-6">
      <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
        <p class="text-sm text-slate-300">
          &copy; {currentYear} topbestllcservice.com. All rights reserved.
        </p>
        <div class="flex items-center gap-4">
          <a href="/privacy-policy/" class="text-xs text-slate-400 hover:text-white">Privacy</a>
          <span class="text-slate-600">&middot;</span>
          <a href="/terms/" class="text-xs text-slate-400 hover:text-white">Terms</a>
          <span class="text-slate-600">&middot;</span>
          <a href="/affiliate-disclosure/" class="text-xs text-slate-400 hover:text-white">Disclosure</a>
        </div>
      </div>
      <p class="mt-3 text-center text-[11px] text-slate-500 sm:text-left">
        Operated by Eximia Ltd.
      </p>
    </div>
  </div>
</footer>
